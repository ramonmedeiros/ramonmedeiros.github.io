---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="404 — Page Not Found" description="Page not found" />
		<style>
			.container {
				margin: 10px auto;
				max-width: 600px;
				text-align: center;
			}
			h1 {
				margin: 30px 0;
				font-size: 4em;
				line-height: 1;
				letter-spacing: -1px;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="container">
				<h1>404</h1>
				<p><strong>Page not found :(</strong></p>
				<p>The requested page could not be found.</p>
			</div>
		</main>
		<Footer />
	</body>
</html>
